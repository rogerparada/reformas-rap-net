      "quantity": 12
    }
    
  ]
}

### Edit Document
PUT {{Api_URL}}/api/Document/{{document_id}}
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "numeroDocumento": "FAC-001",
  "tipoDocumento": "Factura",
  "fecha": "2026-04-07T09:36:54.24196Z",
  "estado": 1,
  "iva": true,
  "idCliente": "{{id_cliente}}",
  "items": [
    {
      "descripcion": "Maderas",
      "precio": 500.0,
      "cantidad": 2
    },
    {
      "descripcion": "Maderas de roble",
      "importe": 200.0
    }
  ]
}

### Get Documents info
GET http://{{Api_URL}}/api/Document/info?tipo=Factura
Authorization: Bearer {{auth_token}}

### Get Documents info Presupuesto
GET http://{{Api_URL}}/api/Document/info?tipo=Presupuesto
Authorization: Bearer {{auth_token}}
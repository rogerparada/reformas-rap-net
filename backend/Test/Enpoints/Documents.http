@Api_URL = http://localhost:5173
@user_mail = "mail@mail.com"
@user_pass = "ElPasswordMasLargoPosible2026!"


### Login
POST {{Api_URL}}/api/Auth/login
Content-Type: application/json

{
  "email": {{user_mail}},
  "password": {{user_pass}}
}

> {%
    client.global.set("auth_token", response.body.token);
%}

### Get Documentos
GET {{Api_URL}}/api/Document
Content-Type: application/json
Authorization: Bearer {{auth_token}}

> {%
    client.global.set("document_id", response.body[0].idDocumento)
%}

### Create Documento no item
POST {{Api_URL}}/api/Document
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "numeroDocumento": "PRES-002",
  "tipoDocumento": 1,
  "fecha": null,
  "estado": 1,
  "iva": null,
  "idCliente": "{{id_cliente}}"
}

### Create Documento
POST {{Api_URL}}/api/Document
Content-Type: application/json
Authorization: Bearer {{auth_token}}

{
  "numeroDocumento": "Fact-001",
  "fecha": "2026-04-10T00:00:00.000Z",
  "tipoDocumento": "Factura",
  "iva": true,
  "idCliente": "019d7dac-ff5e-79a5-b015-fc611fb33aae",
  "items": [
    {
      "description": "Algo",
      "price": 0,
      "quantity": 0,
      "total": 200.05
    }
  ]
}

